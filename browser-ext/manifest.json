{
  "manifest_version": 3,
  "name": "MICE Browser Guide",
  "version": "0.1.0",
  "description": "Companion browser surface for MICE guide-me highlights.",
  "key": "",
  "permissions": ["activeTab", "tabs", "nativeMessaging"],
  "host_permissions": ["http://*/*", "https://*/*"],
  "action": {},
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
